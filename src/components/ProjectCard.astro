---
import Icon from './Icon.astro';
import type { Project } from '@/data/projects';
import { useTranslations, type Lang } from '@/i18n/ui';

interface Props { project: Project; lang: Lang; index: number }
const { project, lang, index } = Astro.props;
const t = useTranslations(lang);
const featured = index === 0;
---
<article
  class:list={[
    'group relative flex flex-col rounded-2xl border border-line bg-surface/50 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-line-strong hover:bg-surface sm:p-7',
    featured && 'md:col-span-2',
  ]}
  data-reveal
  data-delay={`${index * 80}ms`}
>
  <div class="mb-4 flex items-start justify-between gap-4">
    <div>
      <h3 class="text-xl font-semibold tracking-tight">{project.name}</h3>
      <p class="mt-1.5 text-sm text-accent/90">{project.tagline[lang]}</p>
    </div>
    <span class="mono-label shrink-0 pt-1">{project.year}</span>
  </div>

  <p class="mb-6 flex-1 text-sm leading-relaxed text-muted">{project.description[lang]}</p>

  <ul class="mb-6 flex flex-wrap gap-2">
    {project.tech.map((tech) => (
      <li class="rounded-md border border-line bg-bg/60 px-2.5 py-1 font-mono text-xs text-muted">
        {tech}
      </li>
    ))}
  </ul>

  <div class="flex items-center gap-4 border-t border-line pt-5 text-sm">
    {project.github && (
      <a
        href={project.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-muted transition-colors hover:text-text"
      >
        <Icon name="github" class="size-4" />
        {t('projects.code')}
      </a>
    )}
    {project.demo && (
      <a
        href={project.demo}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-muted transition-colors hover:text-text"
      >
        <Icon name="external" class="size-4" />
        {t('projects.demo')}
      </a>
    )}
  </div>
</article>
