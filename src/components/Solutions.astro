---
import Section from './Section.astro';
import Icon from './Icon.astro';
import { solutions } from '@/data/solutions';
import { useTranslations, type Lang } from '@/i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<Section id="solutions" label={t('solutions.label')} title={t('solutions.title')}>
  <p class="mb-9 max-w-2xl text-pretty leading-relaxed text-muted" data-reveal>
    {t('solutions.intro')}
  </p>

  <div class="grid gap-5 md:grid-cols-2">
    {
      solutions.map((s, i) => (
        <article
          class="group relative flex flex-col rounded-2xl border border-line bg-surface/50 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-line-strong hover:bg-surface sm:p-7"
          data-reveal
          data-delay={`${i * 80}ms`}
        >
          <div class="mb-4 flex items-start justify-between gap-4">
            <h3 class="text-lg font-semibold tracking-tight">{s.name[lang]}</h3>
            <span class="mono-label shrink-0 pt-1 text-accent/80">{s.context}</span>
          </div>

          <p class="mb-5 text-sm text-accent/90">{s.tagline[lang]}</p>

          <ul class="mb-6 flex-1 space-y-2">
            {s.highlights[lang].map((h) => (
              <li class="flex gap-3 text-sm leading-relaxed text-text/85">
                <Icon name="arrow-up-right" class="mt-1 size-3.5 shrink-0 text-accent/70" />
                <span>{h}</span>
              </li>
            ))}
          </ul>

          <ul class="flex flex-wrap gap-2 border-t border-line pt-5">
            {s.tech.map((tech) => (
              <li class="rounded-md border border-line bg-bg/60 px-2.5 py-1 font-mono text-xs text-muted">
                {tech}
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</Section>
