---
import { site } from '@/data/site';
import { useTranslations, type Lang } from '@/i18n/ui';
import Icon from './Icon.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="relative mx-auto flex min-h-[92vh] max-w-5xl flex-col justify-center px-5 pb-16 pt-28 sm:px-8">
  <div class="max-w-3xl">
    <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-line bg-surface/60 px-3 py-1.5 text-xs text-muted" data-reveal>
      <span class="relative flex size-2">
        <span class="absolute inline-flex size-full animate-ping rounded-full bg-accent opacity-60"></span>
        <span class="relative inline-flex size-2 rounded-full bg-accent"></span>
      </span>
      {t('hero.status')}
    </p>

    <p class="mb-4 font-mono text-sm font-medium uppercase tracking-[0.16em] text-accent" data-reveal data-delay="60ms">
      {site.role[lang]}
    </p>

    <h1 class="text-4xl font-semibold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl" data-reveal data-delay="120ms">
      {site.name}
    </h1>

    <p class="mt-6 max-w-2xl text-balance text-xl text-text/90 sm:text-2xl" data-reveal data-delay="180ms">
      {t('hero.tagline')}
    </p>

    <p class="mt-5 max-w-2xl text-pretty leading-relaxed text-muted" data-reveal data-delay="240ms">
      {t('hero.intro')}
    </p>

    <div class="mt-9 flex flex-wrap items-center gap-3" data-reveal data-delay="300ms">
      <a
        href="#projects"
        class="group inline-flex items-center gap-2 rounded-lg bg-text px-5 py-2.5 text-sm font-medium text-bg transition-transform hover:-translate-y-0.5"
      >
        {t('hero.cta.work')}
        <Icon name="arrow-down" class="size-4 transition-transform group-hover:translate-y-0.5" />
      </a>
      <a
        href={site.cv}
        download
        class="inline-flex items-center gap-2 rounded-lg border border-line bg-surface/60 px-5 py-2.5 text-sm font-medium text-text transition-colors hover:border-line-strong hover:bg-surface"
      >
        <Icon name="download" class="size-4" />
        {t('hero.cta.cv')}
      </a>

      <div class="ml-1 flex items-center gap-1">
        <a
          href={site.socials.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="grid size-10 place-items-center rounded-lg border border-line bg-surface/60 text-muted transition-colors hover:border-line-strong hover:text-text"
        >
          <Icon name="github" class="size-5" />
        </a>
        <a
          href={site.socials.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="grid size-10 place-items-center rounded-lg border border-line bg-surface/60 text-muted transition-colors hover:border-line-strong hover:text-text"
        >
          <Icon name="linkedin" class="size-5" />
        </a>
      </div>
    </div>
  </div>
</section>
