---
import Section from './Section.astro';
import Icon from './Icon.astro';
import { experience } from '@/data/experience';
import { useTranslations, type Lang } from '@/i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<Section id="work" label={t('work.label')} title={t('work.title')}>
  <ol class="relative border-l border-line">
    {
      experience.map((job, i) => (
        <li class="relative ml-6 pb-10 last:pb-0" data-reveal data-delay={`${i * 80}ms`}>
          <span
            class:list={[
              'absolute -left-[1.7rem] top-1.5 grid size-3 place-items-center rounded-full ring-4 ring-bg',
              job.current ? 'bg-accent' : 'bg-line-strong',
            ]}
          />
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <h3 class="text-lg font-semibold">
              <span>{job.role[lang]}</span>
              <span class="text-muted"> · </span>
              {job.url ? (
                <a
                  href={job.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="link-underline text-accent"
                >
                  {job.company}
                </a>
              ) : (
                <span class="text-accent">{job.company}</span>
              )}
            </h3>
            <span class="mono-label">{job.period[lang]}</span>
          </div>

          <p class="mt-3 max-w-2xl leading-relaxed text-muted">{job.summary[lang]}</p>

          <ul class="mt-4 space-y-2">
            {job.highlights[lang].map((h) => (
              <li class="flex gap-3 text-sm leading-relaxed text-text/85">
                <Icon name="arrow-up-right" class="mt-1 size-3.5 shrink-0 text-accent/70" />
                <span>{h}</span>
              </li>
            ))}
          </ul>

          <ul class="mt-5 flex flex-wrap gap-2">
            {job.stack.map((tech) => (
              <li class="rounded-md border border-line bg-surface px-2.5 py-1 font-mono text-xs text-muted">
                {tech}
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</Section>
