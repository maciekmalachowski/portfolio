---
import '@/styles/global.css';
import { site } from '@/data/site';
import { type Lang } from '@/i18n/ui';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}
const { lang, title, description } = Astro.props;

const pageTitle = title ?? `${site.name} — ${site.role[lang]}`;
const pageDesc =
  description ??
  (lang === 'pl'
    ? 'AI Engineer budujący produkcyjne systemy LLM i workflow agentowe. Portfolio Macieja Małachowskiego.'
    : 'AI Engineer building production LLM systems and agentic workflows. Portfolio of Maciej Małachowski.');
const canonical = new URL(Astro.url.pathname, site.socials.website).href;
const ogImage = new URL('/favicon.ico', site.socials.website).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="author" content={site.name} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#09090b" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary" />

    <!-- Alternate language -->
    <link rel="alternate" hreflang="en" href={new URL('/', site.socials.website).href} />
    <link rel="alternate" hreflang="pl" href={new URL('/pl/', site.socials.website).href} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: site.name,
        jobTitle: 'AI Engineer',
        email: `mailto:${site.email}`,
        url: site.socials.website,
        sameAs: [site.socials.github, site.socials.linkedin],
      })}
    />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-surface focus:px-4 focus:py-2 focus:text-sm"
    >
      Skip to content
    </a>
    <slot />

    <!-- Scroll-reveal: progressively enhances [data-reveal] elements -->
    <script>
      const els = document.querySelectorAll('[data-reveal]');
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                (e.target as HTMLElement).style.transitionDelay =
                  (e.target as HTMLElement).dataset.delay ?? '0ms';
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
